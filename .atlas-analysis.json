    "expr::hash_string() - Compile-time string hashing",
    "symbol() - Access raw strings in PIC",
    "RESOLVE_API() - Macro for convenient API resolution",
    "RESOLVE_IMPORT() - Macro for batch import resolution",
    "memory::zero() - Secure memory zeroing",
